    "enabled": false,
    "enabledExplore": true,
    "exploreUrl": "总点击::/top/allvisit_{{page}}.html\n月点击::/top/monthvisit_{{page}}.html\n周点击::/top/weekvisit_{{page}}.html\n\n推荐榜::/top/allvote_{{page}}.html\n收藏榜::/top/goodnum_{{page}}.html\n新入库::/top/postdate_{{page}}.html\n\n已完结::/full/{{page}}.html",
    "lastUpdateTime": 0,
    "ruleBookInfo": {
      "canReName": "true",
      "intro": "[property=\"og:description\"]@content",
      "kind": "[property=\"og:novel:category\"]@content&&[property=\"og:novel:status\"]@content&&[property=\"og:novel:update_time\"]@content##\\s.*",
      "lastChapter": "[property=\"og:novel:latest_chapter_name\"]@content",
      "wordCount": ".catalognovel_type .p3@text"
    },
    "ruleContent": {
      "content": ".chapter_content@textNodes",
      "nextContentUrl": "text.下一页@href",
      "replaceRegex": "##\\s*.*{{book.durChapterTitle}}\\s*|\\s*本章还未完.*>\\s*|\\s*您.*fryutong.com\\s*提供的\\s*.*\\s*"
    },
    "ruleExplore": {
      "author": ".p3@text||.novel_author@text",
      "bookList": ".list_ul li||.novel_box",
      "bookUrl": "tag.a.0@href",
      "coverUrl": "tag.a.0@href##/(\\d+)##$1###\n@js:var xid=Math.floor(result/1000);'http://www.fryutong.com/files/article/image/'+xid+'/'+result+'/'+result+'s.jpg'",
      "intro": "p.novel_intro@textNodes",
      "kind": ".p6,.p5@text##\\s.*",
      "lastChapter": ".p2@text||.novel_newest p@text",
      "name": ".p1@text||.novel_name@text",
      "wordCount": ".p4@text##K@js:'约' + parseInt(result*0.0512) + '万'"
    },
    "ruleSearch": {
      "author": ".newbook_author@text",
      "bookList": "div.sort_box_list",
      "bookUrl": "tag.a.0@href##^##http://www.fryutong.com",
      "coverUrl": "img@src##.*nocover.*",
      "intro": ".newbook_intor@textNodes",
      "kind": ".s1@text",
      "name": ".newbook_title@text"
    },
    "ruleToc": {
      "chapterList": "div.listchapter ul a",
      "chapterName": "text",
      "chapterUrl": "href",
      "nextTocUrl": "text.下一页@href"
    },
    "searchUrl": "http://m.fryutong.com/search.php,{\n\"charset\": \"gbk\",\n\"method\": \"POST\",\n\"body\": \"searchkey={{key}}\"\n}",
    "weight": 0
  }]